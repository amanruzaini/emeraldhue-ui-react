{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@eh/tokens/*": ["../tokens/*"],
      "@eh/components": ["../components/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.mdx", "next-env.d.ts"],
  "exclude": ["node_modules", ".next"]
}
