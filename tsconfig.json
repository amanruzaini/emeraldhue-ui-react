{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@eh/tokens": ["packages/tokens/src"],
      "@eh/tokens/*": ["packages/tokens/src/*"],
      "@eh/components": ["packages/components/src"],
      "@eh/components/*": ["packages/components/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
